# Copy this file to .env and fill in real values. NEVER commit the real .env.

# Server
PORT=5000

# Database
MONGO_URI=mongodb://localhost:27017/hostel-management

# Auth
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRE=7d

# Email (leave EMAIL_HOST blank for dev/console mode; set for real SMTP)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# Frontend base URL used in email links (must match where Vite serves)
CLIENT_URL=http://localhost:3000
